# SuperRecord — 환경변수 설정
# 이 파일을 .env로 복사하고 값을 채우세요: cp .env.example .env
# Agent와 함께 설정: "초기 설정" 또는 "init" 요청

# ─── DashScope (ASR) ──────────────────────────────────────
# Alibaba Cloud Model Studio에서 발급
# https://dashscope-intl.console.aliyun.com → API Keys
DASHSCOPE_API_KEY=

# ─── OSS (오디오 업로드용) ────────────────────────────────
# Agent-guided init에서 자동 생성됨 (AGENTS.md Init Step 4 참조)
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_ENDPOINT=oss-ap-southeast-1.aliyuncs.com
OSS_PREFIX=superrecord
OSS_SIGNED_URL_TTL=86400
